# =============================================================================
# .NET / ASP.NET Core — Microsoft Agent Framework API
# =============================================================================
# Covers: .NET build output, Visual Studio, Rider, VS Code, NuGet,
#         test results, publish profiles, secrets, OS artifacts, and tooling.
# =============================================================================


# -----------------------------------------------------------------------------
# .NET Build Output
# Compiled binaries and intermediate files are always regenerated by the SDK.
# Never commit these — they are large, binary, and machine-specific.
# -----------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
out/
publish/
*.dll
*.exe
*.pdb
*.ilk
*.meta

# Natively compiled output
[Ll]og/
[Ll]ogs/


# -----------------------------------------------------------------------------
# Visual Studio
# .vs/ is a local IDE state directory — fully machine-specific and binary.
# .suo files store IDE window layout and breakpoints.
# .user files store per-developer project settings (startup args, etc.).
# -----------------------------------------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.sln.ide

# Visual Studio cache and test store
.localhistory/
BenchmarkDotNet.Artifacts/

# Visual Studio 2019+ ARM template scaffolding
*.azurewebsites.net.pfx

# VS Crash Dumps
*.dmp


# -----------------------------------------------------------------------------
# Visual Studio Code
# Workspace-level editor settings are machine-specific.
# If your team shares launch.json / extensions.json, remove this entry.
# -----------------------------------------------------------------------------
.vscode/


# -----------------------------------------------------------------------------
# JetBrains Rider
# .idea/ is Rider's workspace folder (equivalent of .vs/ for Visual Studio).
# .DotSettings.user stores per-developer formatting overrides.
# -----------------------------------------------------------------------------
.idea/
*.DotSettings.user


# -----------------------------------------------------------------------------
# NuGet
# Package restore creates these during build — do not commit them.
# The lock file (packages.lock.json) IS intentionally committed if you use it.
# -----------------------------------------------------------------------------
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
nuget.config.user

# NuGet v3+ cache files
project.lock.json
project.fragment.lock.json
artifacts/


# -----------------------------------------------------------------------------
# Test Results & Code Coverage
# Generated on each test run — never source-controlled.
# -----------------------------------------------------------------------------
[Tt]est[Rr]esult*/
*.trx
*.coveragexml
*.coverage
coverage/
CoverageReport/
cobertura.xml
lcov.info
TestResults/


# -----------------------------------------------------------------------------
# Publish Profiles
# Contain environment-specific deployment targets (URLs, credentials).
# Keep generic profiles in source control only if they have no secrets.
# -----------------------------------------------------------------------------
**/Properties/PublishProfiles/
PublishScripts/
**/app_offline.htm
**/[Ww]eb.config.transform


# -----------------------------------------------------------------------------
# Entity Framework Core Migrations (generated)
# Only ignore if you regenerate migrations from scratch; otherwise keep them.
# Uncomment the line below if migrations are generated, not hand-written.
# -----------------------------------------------------------------------------
# **/Migrations/


# -----------------------------------------------------------------------------
# Secrets & Credentials
# NEVER commit API keys, passwords, certificates, or connection strings.
#
# Best practice for this project:
#   • appsettings.json           → COMMITTED  (base config, placeholders only)
#   • appsettings.*.json         → IGNORED    (environment overrides with secrets)
#   • Use `dotnet user-secrets` or environment variables for local dev secrets.
#   • Use Azure Key Vault or CI/CD secret stores for production.
# -----------------------------------------------------------------------------

# Environment-specific appsettings contain real endpoints and API keys.
# Only the base appsettings.json (no secrets) is committed.
appsettings.*.json

.env
.env.*
!.env.example
secrets.json
**/secrets.json
**/*[Ss]ecret*
**/*[Cc]redential*
*.pfx
*.p12
*.pem
*.key
*.cer

# Azure publish profiles with embedded credentials
*.PublishSettings
*.azurePubxml
**/app_offline.htm


# -----------------------------------------------------------------------------
# OS-Generated Files
# Created by macOS, Windows Explorer, and Linux file managers.
# These have no relevance to the project and differ per machine.
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
Icon

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# -----------------------------------------------------------------------------
# Claude Code (AI Assistant)
# .claude/ contains local session state, plan files, and per-machine settings.
# This is equivalent to .vs/ — machine-specific and should not be shared.
# -----------------------------------------------------------------------------
.claude/


# -----------------------------------------------------------------------------
# Misc Development Tooling
# -----------------------------------------------------------------------------

# Docker
docker-compose.override.yml

# Terraform state (if infra-as-code is added later)
*.tfstate
*.tfstate.*
.terraform/

# StyleCop / Roslyn analyzers cache
.cache/

# Rider/ReSharper generated code
_ReSharper*/
*.ReSharper

# dotnet-format output
.dotnet-format/
