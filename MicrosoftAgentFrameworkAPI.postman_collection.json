      "item": [
        {
          "name": "Agent Calls GetWeather Tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"message\": \"What is the weather like in Amsterdam?\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/agent/run",
              "host": ["{{base_url}}"],
              "path": ["api", "agent", "run"]
            },
            "description": "The agent detects weather intent, calls `GetWeather(\"Amsterdam\")`, and returns a natural-language response with the temperature.\n\nExpected response: mentions Amsterdam and contains temperature (°C or °F)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has \"response\" field', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('response');",
                  "});",
                  "",
                  "pm.test('Response mentions Amsterdam', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.response.toLowerCase()).to.include('amsterdam');",
                  "});",
                  "",
                  "pm.test('Response contains temperature data', function () {",
                  "    var json = pm.response.json();",
                  "    var body = json.response;",
                  "    var hasTemp = body.includes('\\u00b0C') || body.includes('\\u00b0F') ||",
                  "                  body.toLowerCase().includes('temperature') ||",
                  "                  body.toLowerCase().includes('celsius') ||",
                  "                  body.toLowerCase().includes('fahrenheit');",
                  "    pm.expect(hasTemp).to.be.true;",
                  "});"
