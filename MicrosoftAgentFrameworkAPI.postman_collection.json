    {
      "name": "Phase 5 — Workflows",
      "description": "Workflows (Tutorial Step 5).\n\nChains two executor steps sequentially:\n1. **UppercaseExecutor** — converts input to uppercase\n2. **ReverseTextExecutor** — reverses the uppercase string\n\nThe response shows each step's output.",
      "item": [
        {
          "name": "Run Text Pipeline — Standard Input",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"text\": \"Hello, World! This is Agent Framework.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/workflow/run",
              "host": ["{{base_url}}"],
              "path": ["api", "workflow", "run"]
            },
            "description": "Runs the text through the two-step pipeline.\n\nExpected response:\n```json\n{\n  \"input\": \"Hello, World! This is Agent Framework.\",\n  \"steps\": [\n    { \"step\": \"UppercaseExecutor\", \"output\": \"HELLO, WORLD! THIS IS AGENT FRAMEWORK.\" },\n    { \"step\": \"ReverseTextExecutor\", \"output\": \".KROWEMARF TNEGA SI SIHT !DLROW ,OLLEH\" }\n  ]\n}\n```"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has input and steps array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('input');",
                  "    pm.expect(json).to.have.property('steps');",
                  "    pm.expect(json.steps).to.be.an('array').and.not.empty;",
                  "});",
                  "",
                  "pm.test('UppercaseExecutor output is correct', function () {",
                  "    var json = pm.response.json();",
                  "    var step = json.steps.find(function(s) { return s.step === 'UppercaseExecutor'; });",
                  "    pm.expect(step).to.not.be.undefined;",
                  "    pm.expect(step.output).to.equal('HELLO, WORLD! THIS IS AGENT FRAMEWORK.');",
                  "});",
                  "",
                  "pm.test('ReverseTextExecutor output is correct', function () {",
                  "    var json = pm.response.json();",
                  "    var step = json.steps.find(function(s) { return s.step === 'ReverseTextExecutor'; });",
                  "    pm.expect(step).to.not.be.undefined;",
                  "    pm.expect(step.output).to.equal('.KROWEMARF TNEGA SI SIHT !DLROW ,OLLEH');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Run Text Pipeline — Simple Sanity Check",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"text\": \"hello\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/workflow/run",
              "host": ["{{base_url}}"],
              "path": ["api", "workflow", "run"]
            },
            "description": "Simple sanity check: `hello` → `HELLO` → `OLLEH`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('UppercaseExecutor returns HELLO', function () {",
                  "    var json = pm.response.json();",
                  "    var step = json.steps.find(function(s) { return s.step === 'UppercaseExecutor'; });",
                  "    pm.expect(step.output).to.equal('HELLO');",
                  "});",
                  "",
                  "pm.test('ReverseTextExecutor returns OLLEH', function () {",
