<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)system.clientmodel\1.10.0\buildTransitive\net10.0\System.ClientModel.targets" Condition="Exists('$(NuGetPackageRoot)system.clientmodel\1.10.0\buildTransitive\net10.0\System.ClientModel.targets')" />
    <Import Project="$(NuGetPackageRoot)openai\2.10.0\buildTransitive\netstandard2.0\OpenAI.targets" Condition="Exists('$(NuGetPackageRoot)openai\2.10.0\buildTransitive\netstandard2.0\OpenAI.targets')" />
    <Import Project="$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.2\build\Microsoft.AspNetCore.OpenApi.targets" Condition="Exists('$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.2\build\Microsoft.AspNetCore.OpenApi.targets')" />
    <Import Project="$(NuGetPackageRoot)azure.core\1.53.0\buildTransitive\net10.0\Azure.Core.targets" Condition="Exists('$(NuGetPackageRoot)azure.core\1.53.0\buildTransitive\net10.0\Azure.Core.targets')" />
    <Import Project="$(NuGetPackageRoot)azure.ai.projects.agents\2.1.0-beta.1\buildTransitive\net10.0\Azure.AI.Projects.Agents.targets" Condition="Exists('$(NuGetPackageRoot)azure.ai.projects.agents\2.1.0-beta.1\buildTransitive\net10.0\Azure.AI.Projects.Agents.targets')" />
    <Import Project="$(NuGetPackageRoot)azure.ai.projects\2.1.0-beta.1\buildTransitive\net10.0\Azure.AI.Projects.targets" Condition="Exists('$(NuGetPackageRoot)azure.ai.projects\2.1.0-beta.1\buildTransitive\net10.0\Azure.AI.Projects.targets')" />
  </ImportGroup>
</Project>